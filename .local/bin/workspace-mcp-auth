#!/usr/bin/env bash
#
# workspace-mcp-auth — authenticate a Google account for the google_workspace_mcp
# servers (workspace-js / workspace-personal) used by Claude Code.
#
# Runs the Google OAuth consent flow in your browser and writes the resulting
# token where the stdio MCP servers read it (WORKSPACE_MCP_CREDENTIALS_DIR), so
# the running servers pick it up on their next tool call.
#
# It reuses the existing OAuth client secrets created for the Gmail MCP server
# and requests the full "complete" tool-tier scope set (computed from the
# installed package, so it stays correct across upgrades). The local callback
# listens on port 3000, whose /oauth2callback redirect is registered on both
# OAuth clients.
#
# Usage:
#   workspace-mcp-auth js         # salim@junglescout.com
#   workspace-mcp-auth personal   # salimhamed@gmail.com
#
# Pre-select the matching Google account's Chrome profile before running; this
# script does not manage profiles. login_hint pre-fills the expected account.

set -euo pipefail

wma_account="${1:-}"
case "$wma_account" in
    js)
        wma_secret="$HOME/.gmail-mcp-junglescout/gcp-oauth.keys.json"
        wma_creds_dir="$HOME/.google_workspace_mcp-junglescout/credentials"
        wma_email="salim@junglescout.com"
        ;;
    personal)
        wma_secret="$HOME/.gmail-mcp-personal/gcp-oauth.keys.json"
        wma_creds_dir="$HOME/.google_workspace_mcp-personal/credentials"
        wma_email="salimhamed@gmail.com"
        ;;
    *)
        echo "Usage: workspace-mcp-auth <js|personal>" >&2
        exit 1
        ;;
esac

if [[ ! -f "$wma_secret" ]]; then
    echo "OAuth client secret not found: $wma_secret" >&2
    exit 1
fi

export WMA_SECRET="$wma_secret"
export WMA_CREDS_DIR="$wma_creds_dir"
export WMA_EMAIL="$wma_email"
export WMA_PORT="3000"
# Local loopback callback is plain HTTP; relax oauthlib's HTTPS-only and
# strict-scope checks (Google may reorder/augment the granted scope list).
export OAUTHLIB_INSECURE_TRANSPORT="1"
export OAUTHLIB_RELAX_TOKEN_SCOPE="1"

uvx --from workspace-mcp python - <<'PY'
import os, sys, json, base64, subprocess, webbrowser
import http.server, urllib.parse
from google_auth_oauthlib.flow import Flow
from auth import scopes as S
from auth.credential_store import LocalDirectoryCredentialStore

secret = os.environ["WMA_SECRET"]
creds_dir = os.environ["WMA_CREDS_DIR"]
expected_email = os.environ["WMA_EMAIL"]
port = int(os.environ["WMA_PORT"])
redirect = f"http://localhost:{port}/oauth2callback"

# "complete" tool-tier scopes: base identity scopes + every tool's scopes.
scopes = sorted({*S.BASE_SCOPES, *(s for grp in S.TOOL_SCOPES_MAP.values() for s in grp)})

flow = Flow.from_client_secrets_file(secret, scopes=scopes, redirect_uri=redirect)
auth_url, _ = flow.authorization_url(
    access_type="offline",
    prompt="consent",
    include_granted_scopes="false",
    login_hint=expected_email,
)

captured = {}

class CallbackHandler(http.server.BaseHTTPRequestHandler):
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        if parsed.path != "/oauth2callback":
            self.send_response(404)
            self.end_headers()
            return
        captured.update(urllib.parse.parse_qs(parsed.query))
        self.send_response(200)
        self.send_header("Content-Type", "text/html")
        self.end_headers()
        ok = "code" in captured
        note = "Authorization complete — you can close this tab." if ok else "Authorization failed."
        self.wfile.write(f"<html><body><h2>{note}</h2></body></html>".encode())

    def log_message(self, *args):
        pass

print(f"\nAuthorizing {expected_email} (port {port}) ...")
print("Opening your browser — pick the matching account in your pre-selected Chrome profile.\n")
if subprocess.run(["open", auth_url], check=False).returncode != 0:
    webbrowser.open(auth_url)
print("If the browser didn't open, paste this URL manually:\n" + auth_url + "\n")

server = http.server.HTTPServer(("localhost", port), CallbackHandler)
while "code" not in captured and "error" not in captured:
    server.handle_request()

if "error" in captured:
    print("OAuth error: " + captured["error"][0], file=sys.stderr)
    sys.exit(1)

flow.fetch_token(code=captured["code"][0])
creds = flow.credentials

# Label the stored file by the authenticated email (from the id_token payload).
email = expected_email
if creds.id_token:
    try:
        payload = creds.id_token.split(".")[1]
        payload += "=" * (-len(payload) % 4)
        email = json.loads(base64.urlsafe_b64decode(payload)).get("email", expected_email)
    except Exception:
        pass

if email.lower() != expected_email.lower():
    print(f"WARNING: authorized {email}, expected {expected_email}.", file=sys.stderr)

LocalDirectoryCredentialStore(base_dir=creds_dir).store_credential(email, creds)
print(f"\nStored credentials for {email} in:\n  {creds_dir}")
print("Done. Retry a Workspace tool in Claude Code to confirm.")
PY
