# Switch gh from Keychain to file-based PAT auth (needed for Codex sandbox)
gh-auth-pat() {
  if [ -z "${GITHUB_PERSONAL_ACCESS_TOKEN:-}" ]; then
    echo "GITHUB_PERSONAL_ACCESS_TOKEN is not set" >&2
    return 1
  fi

  printf '%s\n' "${GITHUB_PERSONAL_ACCESS_TOKEN}" \
    | gh auth login --with-token --insecure-storage
}

# Start Codex with the dotfiles MCP profile.
codex-dotfiles() {
  local cdf_profile_file="${HOME}/.codex/dotfiles.config.toml"

  if [[ ! -f "${cdf_profile_file}" ]]; then
    print -u2 "codex-dotfiles: missing ${cdf_profile_file}"
    return 1
  fi

  codex --profile-v2 dotfiles "$@"
}

# Start Codex with the debug MCP profile.
codex-debug() {
  local cdg_profile_file="${HOME}/.codex/debug.config.toml"

  if [[ ! -f "${cdg_profile_file}" ]]; then
    print -u2 "codex-debug: missing ${cdg_profile_file}"
    return 1
  fi

  codex --profile-v2 debug "$@"
}

# Start Codex with the ad hoc MCP profile.
codex-adhoc() {
  local cad_profile_file="${HOME}/.codex/adhoc.config.toml"

  if [[ ! -f "${cad_profile_file}" ]]; then
    print -u2 "codex-adhoc: missing ${cad_profile_file}"
    return 1
  fi

  codex --profile-v2 adhoc "$@"
}
